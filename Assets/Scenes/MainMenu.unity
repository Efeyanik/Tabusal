      m_Calls: []
  m_text: "Standart mod ile klasik tabu deneyimini en g\xFCzel \u015Fekilde deneyimleyin.\n\n\nBomba
    Modu, orijinal tabu mant\u0131\u011F\u0131 \xFCzerine in\u015Fa edilmi\u015F
    ve Tabu'ya yepyeni bir heyecan katan bir oyun modudur.\n\n\n<color=#FFE100>Bomba
    Modu Oyun Mant\u0131\u011F\u0131 :</color>\n-S\xFCre belli de\u011Fildir.\n\n-Do\u011Fru
    bilindi\u011Finde s\u0131ra rakip tak\u0131ma ge\xE7er.\n\n-S\xFCre bitti\u011Finde
    anlatamam\u0131\u015F tak\u0131m ya da tabu yapm\u0131\u015F olan tak\u0131m
    o turu kaybeder ve rakip tak\u0131m 1 puan kazan\u0131r.\n\n-Kazanma puan\u0131na
    ula\u015Fan tak\u0131m oyunu kazan\u0131r. \n\n\nOyun ayarlar\u0131ndan oyununuzu
    \xF6zelle\u015Ftirmeyi unutmay\u0131n\u0131z.\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_sharedMaterial: {fileID: 2180264, guid: 8f586378b4e144a9851e7b34d9b748ee, type: 2}
  m_fontSharedMaterials: []
  m_fontMaterial: {fileID: 0}
